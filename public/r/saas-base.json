{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "saas-base",
  "title": "SaaS Base",
  "description": "Blue and white SaaS dashboard theme tokens for shadcn applications.",
  "dependencies": [
    "class-variance-authority",
    "clsx",
    "lucide-react",
    "tailwind-merge",
    "tw-animate-css"
  ],
  "cssVars": {
    "theme": {
      "font-sans": "'Inter', sans-serif",
      "font-mono": "'JetBrains Mono', monospace",
      "font-heading": "var(--font-sans)",
      "font-serif": "'Merriweather', serif",
      "radius": "0.5rem",
      "tracking-normal": "0"
    },
    "light": {
      "background": "#f8fafc",
      "foreground": "#0f172a",
      "card": "#ffffff",
      "card-foreground": "#0f172a",
      "popover": "#ffffff",
      "popover-foreground": "#0f172a",
      "primary": "#2563eb",
      "primary-foreground": "#ffffff",
      "secondary": "#f1f5f9",
      "secondary-foreground": "#0f172a",
      "muted": "#f1f5f9",
      "muted-foreground": "#64748b",
      "accent": "#eff6ff",
      "accent-foreground": "#1d4ed8",
      "destructive": "#e11d48",
      "border": "#e5e7eb",
      "input": "#cbd5e1",
      "ring": "#2563eb",
      "chart-1": "#2563eb",
      "chart-2": "#10b981",
      "chart-3": "#f59e0b",
      "chart-4": "#475569",
      "chart-5": "#0891b2",
      "radius": "0.5rem",
      "sidebar": "#ffffff",
      "sidebar-foreground": "#0f172a",
      "sidebar-primary": "#2563eb",
      "sidebar-primary-foreground": "#ffffff",
      "sidebar-accent": "#eff6ff",
      "sidebar-accent-foreground": "#1d4ed8",
      "sidebar-border": "#e5e7eb",
      "sidebar-ring": "#2563eb",
      "destructive-foreground": "#ffffff",
      "font-sans": "'Inter', sans-serif",
      "font-serif": "Georgia, serif",
      "font-mono": "'JetBrains Mono', monospace",
      "shadow-color": "#0f172a",
      "shadow-opacity": "0.05",
      "shadow-blur": "12px",
      "shadow-spread": "0px",
      "shadow-offset-x": "0px",
      "shadow-offset-y": "4px",
      "letter-spacing": "0",
      "spacing": "0.25rem",
      "shadow-2xs": "0 1px 2px color-mix(in srgb, var(--shadow-color) 6%, transparent)",
      "shadow-xs": "0 1px 3px color-mix(in srgb, var(--shadow-color) 7%, transparent)",
      "shadow-sm": "0 2px 6px color-mix(in srgb, var(--shadow-color) 7%, transparent)",
      "shadow": "0 6px 16px color-mix(in srgb, var(--shadow-color) 8%, transparent)",
      "shadow-md": "0 10px 24px color-mix(in srgb, var(--shadow-color) 9%, transparent)",
      "shadow-lg": "0 18px 36px color-mix(in srgb, var(--shadow-color) 10%, transparent)",
      "shadow-xl": "0 24px 52px color-mix(in srgb, var(--shadow-color) 11%, transparent)",
      "shadow-2xl": "0 32px 72px color-mix(in srgb, var(--shadow-color) 12%, transparent)",
      "tracking-normal": "0"
    },
    "dark": {
      "background": "#f8fafc",
      "foreground": "#0f172a",
      "card": "#ffffff",
      "card-foreground": "#0f172a",
      "popover": "#ffffff",
      "popover-foreground": "#0f172a",
      "primary": "#2563eb",
      "primary-foreground": "#ffffff",
      "secondary": "#f1f5f9",
      "secondary-foreground": "#0f172a",
      "muted": "#f1f5f9",
      "muted-foreground": "#64748b",
      "accent": "#eff6ff",
      "accent-foreground": "#1d4ed8",
      "destructive": "#e11d48",
      "border": "#e5e7eb",
      "input": "#cbd5e1",
      "ring": "#2563eb",
      "chart-1": "#2563eb",
      "chart-2": "#10b981",
      "chart-3": "#f59e0b",
      "chart-4": "#475569",
      "chart-5": "#0891b2",
      "sidebar": "#ffffff",
      "sidebar-foreground": "#0f172a",
      "sidebar-primary": "#2563eb",
      "sidebar-primary-foreground": "#ffffff",
      "sidebar-accent": "#eff6ff",
      "sidebar-accent-foreground": "#1d4ed8",
      "sidebar-border": "#e5e7eb",
      "sidebar-ring": "#2563eb",
      "destructive-foreground": "#ffffff",
      "radius": "0.5rem",
      "font-sans": "'Inter', sans-serif",
      "font-serif": "Georgia, serif",
      "font-mono": "'JetBrains Mono', monospace",
      "shadow-color": "#0f172a",
      "shadow-opacity": "0.05",
      "shadow-blur": "12px",
      "shadow-spread": "0px",
      "shadow-offset-x": "0px",
      "shadow-offset-y": "4px",
      "letter-spacing": "0",
      "spacing": "0.25rem",
      "shadow-2xs": "0 1px 2px color-mix(in srgb, var(--shadow-color) 6%, transparent)",
      "shadow-xs": "0 1px 3px color-mix(in srgb, var(--shadow-color) 7%, transparent)",
      "shadow-sm": "0 2px 6px color-mix(in srgb, var(--shadow-color) 7%, transparent)",
      "shadow": "0 6px 16px color-mix(in srgb, var(--shadow-color) 8%, transparent)",
      "shadow-md": "0 10px 24px color-mix(in srgb, var(--shadow-color) 9%, transparent)",
      "shadow-lg": "0 18px 36px color-mix(in srgb, var(--shadow-color) 10%, transparent)",
      "shadow-xl": "0 24px 52px color-mix(in srgb, var(--shadow-color) 11%, transparent)",
      "shadow-2xl": "0 32px 72px color-mix(in srgb, var(--shadow-color) 12%, transparent)"
    }
  },
  "css": {
    "@layer base": {
      "*": {
        "@apply border-border outline-ring/50": {}
      },
      "body": {
        "@apply bg-background text-foreground": {},
        "letter-spacing": "var(--tracking-normal)",
        "font-feature-settings": "\"cv02\", \"cv03\", \"cv04\", \"cv11\""
      },
      "html": {
        "@apply font-sans": {}
      },
      "::selection": {
        "background": "color-mix(in srgb, var(--primary) 18%, transparent)"
      }
    }
  },
  "type": "registry:base",
  "config": {
    "style": "base-nova",
    "tailwind": {
      "baseColor": "neutral",
      "cssVariables": true
    },
    "iconLibrary": "lucide"
  }
}