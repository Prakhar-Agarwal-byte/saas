{
  "name": "saas",
  "version": "0.1.0",
  "description": "Shared React component library and shadcn registry for SaaS applications.",
  "type": "module",
  "homepage": "https://github.com/Prakhar-Agarwal-byte/saas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prakhar-Agarwal-byte/saas.git"
  },
  "bugs": {
    "url": "https://github.com/Prakhar-Agarwal-byte/saas/issues"
  },
  "files": [
    "src",
    "registry",
    "public/r",
    "registry.json",
    "components.json",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "registry:source": "node scripts/generate-registry.mjs",
    "registry:build": "pnpm registry:source && shadcn build registry.json --output public/r",
    "registry:validate": "pnpm registry:source && shadcn registry validate registry.json",
    "registry:serve": "node scripts/serve-registry.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./app-blocks": {
      "types": "./src/app-blocks.tsx",
      "import": "./src/app-blocks.tsx"
    },
    "./card-frame": {
      "types": "./src/card-frame.ts",
      "import": "./src/card-frame.ts"
    },
    "./labeled-field": {
      "types": "./src/labeled-field.tsx",
      "import": "./src/labeled-field.tsx"
    },
    "./utils": {
      "types": "./src/lib/utils.ts",
      "import": "./src/lib/utils.ts"
    },
    "./use-mobile": {
      "types": "./src/hooks/use-mobile.ts",
      "import": "./src/hooks/use-mobile.ts"
    },
    "./*": {
      "types": "./src/components/ui/*.tsx",
      "import": "./src/components/ui/*.tsx"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "shadcn": "^4.10.0",
    "typescript": "^5"
  }
}
